Checks: >
  bugprone-*,
  clang-analyzer-*,
  performance-*,
  -bugprone-easily-swappable-parameters,
  -bugprone-exception-escape

WarningsAsErrors: "*"

HeaderFilterRegex: ""

CheckOptions:
  - key: bugprone-suspicious-string-compare.WarnOnImplicitComparison
    value: "true"