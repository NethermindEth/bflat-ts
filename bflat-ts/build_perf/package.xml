<package version="1.0">
    <description
    >bflat build-performance tests - compile time measurement</description>

    <author mailto="maksim.menshikov@nethermind.io" />

    <session track_conf="silent">
        <run>
            <script name="build_perf" />
            <arg name="ta">
                <value>agt_main</value>
            </arg>
            <arg name="cs_file">
                <value>big_refs.cs</value>
            </arg>
            <arg name="bflat_image">
                <value>maximmenshikov/bflat-riscv64-zk-test25</value>
            </arg>
            <arg name="bflat_arch">
                <value>riscv64</value>
            </arg>
            <arg name="bflat_libc">
                <value>zisk_sim</value>
                <value>zisk</value>
            </arg>
            <arg name="bflat_stdlib">
                <value>dotnet</value>
            </arg>
            <arg name="verbose">
                <value>FALSE</value>
            </arg>
            <arg name="no_globalization">
                <value>TRUE</value>
            </arg>
            <arg name="no_stacktrace_data">
                <value>TRUE</value>
            </arg>
            <arg name="no_pthread">
                <value>TRUE</value>
            </arg>
            <arg name="no_pie">
                <value>TRUE</value>
            </arg>
            <arg name="bflat_extlib">
                <value
                >https://github.com/NethermindEth/bflat-libziskos:v1.0.0-preview.27</value>
            </arg>
            <!-- Threshold: 0 = disabled. Limit 5 min for big_refs.cs compilation -->
            <arg name="max_build_time_ms">
                <value>300000</value>
            </arg>
        </run>
    </session>
</package>
