<package version="1.0">
    <description>Simple bflat build tests</description>

    <author mailto="maksim.menshikov@nethermind.io" />

    <session track_conf="silent">
        <run>
            <script name="build" />
            <arg name="ta">
                <value>agt_main</value>
            </arg>
            <arg name="cs_file">
                <value>hello.cs</value>
            </arg>
            <arg name="bflat_image">
                <value>nethermindeth/bflat-riscv64:latest</value>
            </arg>
            <arg name="bflat_arch">
                <value>riscv64</value>
            </arg>
            <arg name="bflat_libc">
                <value>zisk</value>
                <value>zisk_sim</value>
            </arg>
            <arg name="bflat_stdlib">
                <value>dotnet</value>
            </arg>
            <arg name="verbose">
                <value>TRUE</value>
            </arg>
            <arg name="no_globalization">
                <value>TRUE</value>
            </arg>
            <arg name="no_stacktrace_data">
                <value>TRUE</value>
            </arg>
            <arg name="no_pthread">
                <value>TRUE</value>
            </arg>
            <arg name="no_pie">
                <value>TRUE</value>
            </arg>
            <arg name="run">
                <value>FALSE</value>
            </arg>
            <arg name="run_timeout_ms">
                <value>600000</value>
            </arg>
            <arg name="bflat_extlib">
                <value
                >https://github.com/NethermindEth/bflat-libziskos:v1.0.0-preview.27</value>
            </arg>
            <arg name="qemu_path">
                <value>/usr/bin/qemu-riscv64-static</value>
            </arg>
            <arg name="zisk_image">
                <value>nethermindeth/zisk:latest</value>
            </arg>
        </run>
    </session>
</package>
