<package version="1.0">
    <description
    >Nethermind ZiskGuest integration tests - stateless block execution on Zisk</description>

    <author mailto="maksim.menshikov@nethermind.io" />

    <session track_conf="silent">
        <!--
            Common parameters for all ZiskGuest test cases.

            binary         - path to the pre-built nethermind ELF, resolved
                             relative to the installed package directory, or
                             the special value "default" which resolves to
                             ${TS_TOPDIR}/bflat-ts/zisk_guest/bin/nethermind
                             when TS_TOPDIR is set.

            input_bin      - path to the serialised block+witness file,
                             relative to the installed package directory.

                             Payload format expected by the guest is a
                             version-prefixed SSZ blob:

                                 schema: u16be | ssz_bytes

                             where schema 0 selects SszExecutionPayloadV3
                             (pre-Amsterdam) and 1 selects V4.  The file itself
                             is additionally framed the way the ziskemu
                             "inputs" option requires since Zisk v0.16.0:

                                 len: u64le | bytes[len] | zero-padding to 8

                             Inputs live in inputs/<block>.ssz.  The pre-SSZ
                             *.bin inputs are no longer accepted by the guest
                             and have been dropped.

            expected_hash  - block hash to verify against the emulator output.
                             Use "-" to skip hash verification (smoke test only).

            expected_stdout - expected stdout string for the run step.
                             Use "-" to skip stdout verification.

            run_timeout_ms - ziskemu timeout in milliseconds.
                             30 minutes is generous; adjust per block complexity.

            zisk_image     - Zisk Docker image.  Use "-" for the compiled-in
                             default (TSAPI_ZISK_DEFAULT_IMAGE).

            zisk_ta        - agent to run the Zisk container on.  If omitted or
                             equal to "ta", the same agent handles everything.
        -->
        <run-template name="zisk_guest_run">
            <arg name="ta">
                <value>agt_main</value>
            </arg>
            <arg name="binary">
                <value>default</value>
            </arg>
            <arg name="expected_stdout">
                <value>-</value>
            </arg>
            <arg name="zisk_image">
                <value>nethermindeth/zisk:latest</value>
            </arg>
            <arg name="run_timeout_ms">
                <value>1800000</value>
            </arg>
            <arg name="zisk_ta">
                <value>agt_zisk</value>
            </arg>
        </run-template>

        <!--
            Prologue: build the ZiskGuest ELF binary before any test runs.
            Skipped automatically if the binary already exists at
            ${TS_TOPDIR}/bflat-ts/zisk_guest/bin/nethermind.
        -->
        <prologue>
            <script name="build_guest" />
            <arg name="ta"><value>agt_main</value></arg>
            <arg name="bflat_image"><value
                >-</value></arg>
        </prologue>

